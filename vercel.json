{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://splicing-compel-enduring.ngrok-free.dev/api/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "https://splicing-compel-enduring.ngrok-free.dev/images/$1"
    },
    {
      "source": "/files/(.*)",
      "destination": "https://splicing-compel-enduring.ngrok-free.dev/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}